@model List<medicalapp.Models.Appointment>
@{
    ViewData["Title"] = "Doctor Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Doctor Dashboard</h2>
    <a asp-action="Schedule" class="btn btn-outline-primary">📅 Manage Availability</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (ViewBag.NotVerified == true)
{
    <div class="card border-warning bg-warning bg-opacity-10 shadow-sm mb-4 rounded-3">
        <div class="card-body p-4">
            <h4 class="card-title fw-bold text-warning-emphasis">⚠️ Verification Pending</h4>
            <p class="card-text mb-0 text-dark">
                Your medical practitioner credentials are currently under review by our administrator. 
                Once verified, patients will be able to search for your profile and book consultations.
            </p>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm border-0 bg-white rounded-3">
        <div class="card-header bg-white py-3 border-bottom">
            <h5 class="mb-0 fw-bold">Active Patient Bookings</h5>
        </div>
        <div class="card-body p-0">
            @if (Model == null || Model.Count == 0)
            {
                <div class="text-center py-5">
                    <span class="fs-1 text-muted">👥</span>
                    <p class="mt-3 text-muted">You have no upcoming consultation requests.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Patient</th>
                                <th>Gender</th>
                                <th>Age / DOB</th>
                                <th>Date & Time</th>
                                <th>Status</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var app in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold">@app.Patient.FullName</div>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark">@app.Patient.Gender</span>
                                    </td>
                                    <td>
                                        @app.Patient.DateOfBirth.ToString("d")
                                    </td>
                                    <td>
                                        @app.ScheduledDateTime.ToString("f")
                                    </td>
                                    <td>
                                        @if (app.Status == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark">Pending</span>
                                        }
                                        else if (app.Status == "Confirmed")
                                        {
                                            <span class="badge bg-info text-white">Confirmed</span>
                                        }
                                        else if (app.Status == "Completed")
                                        {
                                            <span class="badge bg-success">Completed</span>
                                        }
                                        else if (app.Status == "Cancelled" || app.Status == "Rejected")
                                        {
                                            <span class="badge bg-danger">@app.Status</span>
                                        }
                                        else if (app.Status == "Missed")
                                        {
                                            <span class="badge bg-dark">Missed</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        @if (app.Status == "Pending")
                                        {
                                            <div class="d-flex justify-content-end gap-1">
                                                <form asp-action="ConfirmAppointment" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="appointmentId" value="@app.AppointmentId" />
                                                    <button type="submit" class="btn btn-success btn-sm">Confirm</button>
                                                </form>
                                                <button type="button" class="btn btn-outline-danger btn-sm" onclick="showConfirmModal({
                                                    title: 'Reject Appointment Request',
                                                    message: 'Are you sure you want to reject the appointment request from @app.Patient?.FullName?',
                                                    action: '@Url.Action("RejectAppointment", "Doctors")',
                                                    inputs: { appointmentId: '@app.AppointmentId' },
                                                    buttonText: 'Reject Request',
                                                    buttonClass: 'btn-danger'
                                                })">Reject</button>
                                            </div>
                                        }
                                        else if (app.Status == "Confirmed")
                                        {
                                            <div class="d-flex justify-content-end gap-1">
                                                <a asp-action="CompleteAppointment" asp-route-appointmentId="@app.AppointmentId" class="btn btn-success btn-sm">Complete</a>
                                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="showConfirmModal({
                                                    title: 'Mark Patient as Missed',
                                                    message: 'Are you sure you want to mark @app.Patient?.FullName\'s appointment as missed (no-show)?',
                                                    action: '@Url.Action("MarkAsMissed", "Doctors")',
                                                    inputs: { appointmentId: '@app.AppointmentId' },
                                                    buttonText: 'Missed',
                                                    buttonClass: 'btn-secondary'
                                                })">Missed</button>
                                                <button type="button" class="btn btn-outline-danger btn-sm" onclick="showConfirmModal({
                                                    title: 'Cancel Booking',
                                                    message: 'Are you sure you want to cancel the booking for @app.Patient?.FullName?',
                                                    action: '@Url.Action("CancelAppointment", "Doctors")',
                                                    inputs: { appointmentId: '@app.AppointmentId' },
                                                    buttonText: 'Cancel Booking',
                                                    buttonClass: 'btn-danger'
                                                })">Cancel</button>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}
