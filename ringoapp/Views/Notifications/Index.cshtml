@model List<medicalapp.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
}

<style>
    .notification-link {
        color: inherit;
        text-decoration: none;
        display: block;
    }
    .notification-link:hover .notification-message {
        text-decoration: underline;
        color: #0d6efd !important;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Notifications</h2>
    @if (Model.Any(n => !n.IsRead))
    {
        <form asp-action="MarkAllAsRead" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-primary fw-semibold">
                ✓ Mark All as Read
            </button>
        </form>
    }
</div>

<div class="card shadow-sm border-0 bg-white rounded-3">
    <div class="card-body p-0">
        @if (Model == null || Model.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <span class="fs-1">🔔</span>
                <p class="mt-3 mb-0">No notifications found.</p>
            </div>
        }
        else
        {
            <div class="list-group list-group-flush rounded-3 overflow-hidden">
                @foreach (var n in Model)
                {
                    <div class="list-group-item p-4 transition @(n.IsRead ? "bg-light text-muted" : "bg-white")" style="border-left: @(n.IsRead ? "0" : "4px solid #0d6efd");">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="me-3 flex-grow-1">
                                @if (!string.IsNullOrEmpty(n.TargetUrl))
                                {
                                    <a href="@n.TargetUrl" class="notification-link">
                                        <div class="d-flex align-items-center gap-2 mb-1">
                                            @if (!n.IsRead)
                                            {
                                                <span class="badge bg-primary">New</span>
                                            }
                                            <span class="small text-muted">@n.CreatedAt.ToLocalTime().ToString("g")</span>
                                        </div>
                                        <p class="mb-0 fs-5 notification-message @(n.IsRead ? "text-secondary" : "fw-bold text-dark")">
                                            @n.Message
                                        </p>
                                    </a>
                                }
                                else
                                {
                                    <div>
                                        <div class="d-flex align-items-center gap-2 mb-1">
                                            @if (!n.IsRead)
                                            {
                                                <span class="badge bg-primary">New</span>
                                            }
                                            <span class="small text-muted">@n.CreatedAt.ToLocalTime().ToString("g")</span>
                                        </div>
                                        <p class="mb-0 fs-5 text-dark @(n.IsRead ? "text-secondary" : "fw-bold")">
                                            @n.Message
                                        </p>
                                    </div>
                                }
                            </div>
                            @if (!n.IsRead)
                            {
                                <form asp-action="MarkAsRead" method="post" class="d-inline ms-3">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="notificationId" value="@n.NotificationId" />
                                    <button type="submit" class="btn btn-sm btn-light border text-primary fw-semibold px-3 py-1">
                                        Mark Read
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
