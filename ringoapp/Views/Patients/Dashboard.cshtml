@model List<medicalapp.Models.Appointment>
@{
    ViewData["Title"] = "Patient Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">My Dashboard</h2>
    <a asp-action="SearchDoctors" class="btn btn-primary">🔍 Find a Doctor & Book</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0 bg-white rounded-3">
    <div class="card-header bg-white border-bottom py-3">
        <h5 class="mb-0 fw-bold">Consultation History & Bookings</h5>
    </div>
    <div class="card-body p-0">
        @if (Model == null || Model.Count == 0)
        {
            <div class="text-center py-5">
                <span class="fs-1 text-muted">📅</span>
                <p class="mt-3 text-muted">You have no appointments booked yet.</p>
                <a asp-action="SearchDoctors" class="btn btn-outline-primary btn-sm">Book Your First Consultation</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Doctor</th>
                            <th>Specialization</th>
                            <th>Date & Time</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-light p-2 text-primary me-2 fw-bold text-center" style="width: 38px; height: 38px; line-height: 22px;">
                                            Dr
                                        </div>
                                        <div>
                                            <div class="fw-bold">Dr. @app.Doctor.FullName</div>
                                            <small class="text-muted">@app.Doctor.HospitalName</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">@app.Doctor.Specialization</span>
                                </td>
                                <td>
                                    @app.ScheduledDateTime.ToString("f")
                                </td>
                                <td>
                                    @if (app.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else if (app.Status == "Confirmed")
                                    {
                                        <span class="badge bg-info text-white">Confirmed</span>
                                    }
                                    else if (app.Status == "Completed")
                                    {
                                        <span class="badge bg-success">Completed</span>
                                    }
                                    else if (app.Status == "Cancelled" || app.Status == "Rejected")
                                    {
                                        <span class="badge bg-danger">@app.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-dark">@app.Status</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    @if (app.Status == "Pending" || app.Status == "Confirmed")
                                    {
                                        <button type="button" class="btn btn-outline-danger btn-sm" onclick="showConfirmModal({
                                            title: 'Cancel Appointment',
                                            message: 'Are you sure you want to cancel your appointment with Dr. @app.Doctor?.FullName scheduled on @app.ScheduledDateTime.ToString("g")?',
                                            action: '@Url.Action("CancelAppointment", "Patients")',
                                            inputs: { appointmentId: '@app.AppointmentId' },
                                            buttonText: 'Cancel Appointment',
                                            buttonClass: 'btn-danger'
                                        })">Cancel</button>
                                    }
                                    else if (app.Status == "Completed")
                                    {
                                        <a asp-action="PrintPrescription" asp-route-appointmentId="@app.AppointmentId" target="_blank" class="btn btn-outline-success btn-sm">Print Prescription</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
