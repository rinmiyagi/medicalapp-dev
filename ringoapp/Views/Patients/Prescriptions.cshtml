@model List<medicalapp.Models.Appointment>
@{
    ViewData["Title"] = "My Prescriptions";
}

<h2 class="fw-bold mb-4">My Prescriptions</h2>

<div class="card shadow-sm border-0 bg-white rounded-3">
    <div class="card-header bg-white py-3 border-bottom">
        <h5 class="mb-0 fw-bold">Issued Prescriptions</h5>
    </div>
    <div class="card-body p-0">
        @if (Model == null || Model.Count == 0)
        {
            <div class="text-center py-5">
                <span class="fs-1 text-muted">📄</span>
                <p class="mt-3 text-muted">You have no prescriptions issued yet.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Date</th>
                            <th>Doctor</th>
                            <th>Medications</th>
                            <th>Doctor's Notes</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model)
                        {
                            <tr>
                                <td class="ps-4 text-nowrap">
                                    @app.Prescription.IssuedAt.ToString("d")
                                </td>
                                <td>
                                    <div class="fw-bold">Dr. @app.Doctor.FullName</div>
                                    <small class="text-muted">@app.Doctor.Department.DepartmentName</small>
                                </td>
                                <td>
                                    <div class="p-2 bg-light rounded text-dark font-monospace small" style="white-space: pre-wrap;">@app.Prescription.Medications</div>
                                </td>
                                <td>
                                    <span class="text-muted small">@(string.IsNullOrEmpty(app.Prescription.Notes) ? "No notes added." : app.Prescription.Notes)</span>
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="PrintPrescription" asp-route-appointmentId="@app.AppointmentId" target="_blank" class="btn btn-outline-primary btn-sm">Print / PDF</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
