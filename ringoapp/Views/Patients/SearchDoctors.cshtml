@model List<medicalapp.Models.Doctor>
@{
    ViewData["Title"] = "Find a Doctor";
}

<h2 class="fw-bold mb-4">Find a Doctor</h2>

<div class="card shadow-sm border-0 bg-white rounded-3 mb-4">
    <div class="card-body p-4">
        <form asp-action="SearchDoctors" method="get" class="row g-3">
            <div class="col-md-4">
                <label for="departmentId" class="form-label fw-bold small text-muted">Department</label>
                <select name="departmentId" id="departmentId" class="form-select">
                    <option value="">All Departments</option>
                    @foreach (var dept in (List<medicalapp.Models.MedicalDepartment>)ViewBag.Departments)
                    {
                        if (ViewBag.SelectedDepartmentId != null && (int)ViewBag.SelectedDepartmentId == dept.DepartmentId)
                        {
                            <option value="@dept.DepartmentId" selected>@dept.DepartmentName</option>
                        }
                        else
                        {
                            <option value="@dept.DepartmentId">@dept.DepartmentName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label for="query" class="form-label fw-bold small text-muted">Search by Name, Specialty or Hospital</label>
                <input type="text" name="query" id="query" class="form-control" placeholder="Search..." value="@ViewBag.SearchQuery" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100 py-2">Search</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-4">
    @if (Model == null || Model.Count == 0)
    {
        <div class="col-15 text-center py-5">
            <span class="fs-1 text-muted">🔍</span>
            <p class="mt-3 text-muted">No doctors found matching your criteria.</p>
        </div>
    }
    else
    {
        @foreach (var doctor in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0 bg-white rounded-3">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="rounded-circle bg-primary bg-opacity-10 p-3 text-primary fw-bold text-center me-3" style="width: 50px; height: 50px; line-height: 20px; font-size: 1.25rem;">
                                Dr
                            </div>
                            <div>
                                <h5 class="card-title fw-bold mb-0">Dr. @doctor.FullName</h5>
                                <span class="badge bg-secondary mb-0">@doctor.Department.DepartmentName</span>
                            </div>
                        </div>
                        <hr class="text-muted opacity-25" />
                        <p class="card-text mb-2">
                            <strong>Specialty:</strong> @doctor.Specialization
                        </p>
                        <p class="card-text mb-2">
                            <strong>Hospital:</strong> @doctor.HospitalName
                        </p>
                        <p class="card-text mb-3">
                            <strong>Fee:</strong> <span class="text-primary fw-bold">$@doctor.ConsultationFee.ToString("F2")</span>
                        </p>
                        <div class="d-grid">
                            <a asp-action="BookAppointment" asp-route-doctorId="@doctor.DoctorId" class="btn btn-outline-primary">Book Consultation</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>
