@model List<medicalapp.DTOs.DoctorScheduleDto>
@{
    ViewData["Title"] = "Manage Availability";
    string[] days = { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };
}

<h2 class="fw-bold mb-4">Manage Availability</h2>

<div class="card shadow-sm border-0 bg-white rounded-3">
    <div class="card-header bg-white py-3 border-bottom">
        <h5 class="mb-0 fw-bold">Weekly Consultation Hours</h5>
    </div>
    <div class="card-body p-4">
        <form asp-action="Schedule" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Day of Week</th>
                            <th>Active Availability</th>
                            <th>Start Time</th>
                            <th>End Time</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            <tr>
                                <td>
                                    <strong class="text-secondary">@days[Model[i].DayOfWeek]</strong>
                                    <input type="hidden" asp-for="@Model[i].DayOfWeek" />
                                </td>
                                <td>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input active-toggle" type="checkbox" asp-for="@Model[i].IsActive" id="toggle-@i" />
                                        <label class="form-check-label text-muted small" for="toggle-@i">Accept Bookings</label>
                                    </div>
                                </td>
                                <td>
                                    <input class="form-control time-field" type="time" asp-for="@Model[i].StartTime" id="start-@i" />
                                </td>
                                <td>
                                    <input class="form-control time-field" type="time" asp-for="@Model[i].EndTime" id="end-@i" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <a asp-action="Dashboard" class="btn btn-light px-4">Cancel</a>
                <button type="submit" class="btn btn-primary px-4">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Function to enable/disable time fields based on checkbox toggle state
            function updateFields(index) {
                var toggle = document.getElementById("toggle-" + index);
                var start = document.getElementById("start-" + index);
                var end = document.getElementById("end-" + index);
                if (toggle && start && end) {
                    var active = toggle.checked;
                    start.disabled = !active;
                    end.disabled = !active;
                }
            }

            for (var i = 0; i < 7; i++) {
                updateFields(i);
                (function(index) {
                    var toggle = document.getElementById("toggle-" + index);
                    if (toggle) {
                        toggle.addEventListener("change", function() {
                            updateFields(index);
                        });
                    }
                })(i);
            }
        });
    </script>
}
